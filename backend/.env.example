# ============================================================
# Mana Rasta — Hyderabad Pothole Reporting — Backend Environment Variables
# Copy to .env and fill in values before running.
# NEVER commit .env to version control.
# ============================================================

# ── App ───────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
APP_VERSION=1.0.0
ALLOWED_ORIGINS=http://localhost:3000,https://admin.potholes.hyderabad.gov.in

# ── Database (PostgreSQL + PostGIS) ─────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=pothole_reporter
DB_USER=postgres
DB_PASSWORD=your_secure_password_here
DB_POOL_MAX=20

# Production SSL example:
# DB_SSL=true

# ── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT ───────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=generate_a_very_long_random_secret_here_at_least_64_chars
JWT_EXPIRES_IN=7d

# ── Twilio (OTP SMS) ─────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+1234567890

# ── AWS S3 (image storage) ────────────────────────────────
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=AKIAxxxxxxxxxxxxxxxx
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_S3_BUCKET=mana-rasta-images-prod
CDN_BASE_URL=https://cdn.potholes.hyderabad.gov.in

# ── Image Moderation ─────────────────────────────────────
# Options: sightengine | rekognition | mock
MODERATION_PROVIDER=sightengine

# Sightengine
SIGHTENGINE_USER=your_sightengine_api_user
SIGHTENGINE_SECRET=your_sightengine_api_secret

# ── Firebase (push notifications) ────────────────────────
# Paste the entire service account JSON as a single-line string
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# ── Fraud prevention thresholds ──────────────────────────
FRAUD_IP_DAILY_MAX=20
FRAUD_IP_HOURLY_MAX=8
FRAUD_DEVICE_DAILY_MAX=10
FRAUD_DEVICE_HOURLY_MAX=4
FRAUD_USER_DAILY_MAX=15
FRAUD_USER_HOURLY_MAX=5
FRAUD_COOLDOWN_SECONDS=120

# ── Seeding ───────────────────────────────────────────────
ADMIN_SEED_PASSWORD=Admin@1234!ChangeMe

# ── Logging ───────────────────────────────────────────────
LOG_LEVEL=info

# ML inference service
POTHOLE_ML_SERVICE_URL=http://localhost:8001
POTHOLE_ML_TIMEOUT_MS=8000
POTHOLE_ML_MODEL_VERSION=python-road-heuristic-v1
